# Database password — used by docker-compose for PostgreSQL and the API
DB_PASSWORD=ph_dev_pass

# AWS SSO — required for Athena integration
AWS_SSO_START_URL=https://your-org.awsapps.com/start
AWS_SSO_REGION=us-east-1
AWS_SSO_ACCOUNT_ID=123456789012
AWS_SSO_ROLE_NAME=YourRoleName

# AWS / Athena
AWS_REGION=us-east-1
ATHENA_DATABASE=qa
ATHENA_WORKGROUP=primary
ATHENA_OUTPUT_BUCKET=s3://your-athena-results-bucket/

# Uncomment and set for production:
# NODE_ENV=production
